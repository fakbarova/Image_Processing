    "def histogramEqualization(f, bins=100):\n",
    "    his, be = np.histogram(f, bins=bins)\n",
    "    his = his.astype(float)/sum(his)\n",
    "    return np.interp(f, be, np.hstack((np.zeros((1)), np.cumsum(his))))"
