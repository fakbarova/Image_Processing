    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Function to apply gamma correction\n",
    "def apply_gamma(img, gamma):\n",
    "    img_norm = img / 255.0\n",
    "    gamma_corrected = np.power(img_norm, gamma)\n",
    "    return np.uint8(gamma_corrected * 255)\n",
    "\n",
    "# Load grayscale image\n",
