    "import numpy as np\n",
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1. Create a synthetic grayscale gradient image\n",
    "height, width = 300, 300\n",
    "image = np.tile(np.linspace(0, 255, width, dtype=np.uint8), (height, 1))\n",
    "\n",
    "# 2. Create a circular binary mask\n",
    "mask = np.zeros((height, width), dtype=np.uint8)\n",
    "\n",
    "center = (width // 2, height // 2)\n",
    "radius = 100\n",
    "\n",
    "cv2.circle(mask, center, radius, 255, -1)  # filled circle\n",
    "\n",
    "# 3. Apply the mask using bitwise_and\n",
    "result = cv2.bitwise_and(image, image, mask=mask)\n",
    "\n",
    "# Display results\n",
    "plt.figure(figsize=(12,4))\n",
    "\n",
    "plt.subplot(1,3,1)\n",
    "plt.title(\"Original Image\")\n",
    "plt.imshow(image, cmap='gray')\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.subplot(1,3,2)\n",
    "plt.title(\"Circular Mask\")\n",
    "plt.imshow(mask, cmap='gray')\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.subplot(1,3,3)\n",
    "plt.title(\"Masked Result\")\n",
    "plt.imshow(result, cmap='gray')\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.show()"
