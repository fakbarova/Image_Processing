   },
   "source": [
    "### TASK 2 — Reconstruct an image from selected bit-planes\n",
    "\n",
    "1. Extract bit-planes `b7`, `b6`, `b5` (the three most significant planes).\n",
    "2. Reconstruct an approximation of the original image using only these planes.\n",
    "3. Compare reconstruction vs original visually.\n",
    "\n",
    "Implement below.\n"
   ]
  },
  {
   "cell_type": "code",
   "id": "0486895b",
   "metadata": {
    "id": "0486895b",
    "ExecuteTime": {
     "end_time": "2026-03-11T18:58:12.362418400Z",
     "start_time": "2026-03-11T18:58:12.100121300Z"
    }
   },
   "source": [
    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1. Load a grayscale image\n",
    "image = cv2.imread(\"C:/Users/sudob/OneDrive/Desktop/week5/images/MRI-spine1.tif\", cv2.IMREAD_GRAYSCALE)\n",
    "\n",
    "# 2. Extract bit-planes b7, b6, b5 (MSB planes)\n",
    "b7 = (image >> 7) & 1\n",
    "b6 = (image >> 6) & 1\n",
    "b5 = (image >> 5) & 1\n",
    "\n",
    "# 3. Reconstruct the image using these planes\n",
    "reconstructed = (b7 << 7) + (b6 << 6) + (b5 << 5)\n",
    "\n",
    "# 4. Display original and reconstructed images\n",
    "plt.figure(figsize=(10,4))\n",
    "\n",
    "plt.subplot(1,2,1)\n",
    "plt.title(\"Original Image\")\n",
    "plt.imshow(image, cmap='gray')\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.subplot(1,2,2)\n",
    "plt.title(\"Reconstructed (b7,b6,b5)\")\n",
    "plt.imshow(reconstructed, cmap='gray')\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.show()"
