    "\n",
    "# Stretched image ---------------------------------------------------\n",
    "plt.subplot(223), plt.xticks([]), plt.yticks([])\n",
    "plt.imshow(stretched_img.astype('uint8'), cmap='gray', vmin=0, vmax=255)\n",
    "\n",
    "plt.subplot(224), plt.xlim([0, 255])\n",
    "plt.bar(hist_strch[1][1:], hist_strch[0], color='blue', width=1.5)\n",
    "\n",
    "plt.show()\n",
