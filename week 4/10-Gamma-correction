   "source": [
    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Set gamma value\n",
    "gamma = 0.4  # <1 to brighten an underexposed image\n",
    "\n",
    "# Read the original image\n",
    "img_original = cv2.imread(\"C:/Users/sudob/OneDrive/Desktop/week4/image.jpg\")\n",
    "\n",
    "# Create a lookup table for gamma correction\n",
    "lookUpTable = np.empty((1, 256), np.uint8)\n",
    "for i in range(256):\n",
    "    lookUpTable[0, i] = np.clip(pow(i / 255.0, gamma) * 255.0, 0, 255)\n",
    "\n",
    "# Apply gamma correction using the lookup table\n",
    "out = cv2.LUT(img_original, lookUpTable)\n",
    "\n",
    "# Display original and corrected images side by side\n",
    "plt.figure(figsize=[15, 5])\n",
    "plt.subplot(121)\n",
    "plt.imshow(img_original[..., ::-1])  # Convert BGR → RGB\n",
    "plt.title(\"Original\")\n",
    "plt.subplot(122)\n",
    "plt.imshow(out[..., ::-1])\n",
    "plt.title(\"Gamma Corrected\")\n",
    "plt.show()"
   ],
